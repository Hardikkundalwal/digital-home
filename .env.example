# Digital Home - Environment Configuration Template
# Copy this file to a new file named '.env' and fill in your details

# NASA API Key (optional for Nasa Widget, DEMO_KEY is default)
VITE_NASA_API_KEY=DEMO_KEY

# TMDB API Key (optional for movie recommendations)
VITE_TMDB_API_KEY=

# GitHub Username (optional for GitHub activity monitor)
VITE_GITHUB_USER=

# Firebase Web App Configuration (Required)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
